# ══════════════════════════════════════════════════════════════
#  AfroLuo — Variables d'environnement
#  ⚠️  NE JAMAIS COMMITTER CE FICHIER SUR GITHUB !
#  Ajoute ".env" dans ton .gitignore
# ══════════════════════════════════════════════════════════════

# ── APPLICATION ────────────────────────────────────────────────
APP_NAME=AfroLuo
APP_ENV=development        # development | production
DEBUG=true

# ── BASE DE DONNÉES PostgreSQL ─────────────────────────────────
# Format : postgresql+asyncpg://USER:PASSWORD@HOST:PORT/NOM_BDD
DATABASE_URL=postgresql+asyncpg://afroluo_user:afroluo_pass@localhost:5432/afroluo_db

# Pour Docker Compose, remplace localhost par le nom du service :
# DATABASE_URL=postgresql+asyncpg://afroluo_user:afroluo_pass@db:5432/afroluo_db

# ── JWT (JSON Web Token) ───────────────────────────────────────
# SECRET_KEY : chaîne aléatoire TRÈS longue et secrète
# Génère-la avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_real_secret_key_with_32_chars_minimum
ALGORITHM=HS256
# Durée de validité du token en minutes (ici : 7 jours)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── CORS (Cross-Origin Resource Sharing) ──────────────────────
# Qui peut appeler notre API ? (Flutter en dev tourne sur localhost)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","*"]

# ── FICHIERS AUDIO ─────────────────────────────────────────────
# Dossier où les fichiers MP3/OGG sont stockés
UPLOAD_DIR=uploads
MAX_AUDIO_SIZE_MB=10

# ── PAGINATION ─────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
# ── EMAIL / GMAIL SMTP ─────────────────────────────────────────
# Créer un mot de passe d'application Gmail :
# myaccount.google.com → Sécurité → Mots de passe des applications
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=VOTRE_EMAIL@gmail.com
MAIL_PASSWORD=VOTRE_MOT_DE_PASSE_APPLICATION_GMAIL
MAIL_FROM=VOTRE_EMAIL@gmail.com

# ── GOOGLE OAUTH ───────────────────────────────────────────────
# Créer vos identifiants sur console.cloud.google.com
# APIs et services → Identifiants → Créer ID client OAuth
GOOGLE_CLIENT_ID=VOTRE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=VOTRE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
